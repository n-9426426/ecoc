<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.vehicle.mapper.VehicleTemplateMapper">

    <!--==================== ResultMap ==================== -->
    <resultMap id="VehicleTemplateResult" type="com.ruoyi.vehicle.domain.VehicleTemplate">
        <id     property="templateId"     column="template_id"/>
        <result property="wvtaCocNo"      column="wvta_coc_no"/>
        <result property="cocTemplateNo"     column="coc_template_no"/>
        <result property="modelNo"        column="model_no"/>
        <result property="version"        column="version"/>
        <result property="vehicleType"    column="vehicle_type"/>
        <result property="status"         column="status"/>
        <result property="validateResult" column="validate_result"/>
        <result property="validateTime"   column="validate_time"/>
        <result property="validateMsg"    column="validate_msg"/>
        <result property="json"           column="json"/>
        <result property="remark"         column="remark"/>
        <result property="delFlag"        column="del_flag"/>
        <result property="createBy"       column="create_by"/>
        <result property="createTime"     column="create_time"/>
        <result property="updateBy"       column="update_by"/>
        <result property="updateTime"     column="update_time"/>
        <result property="filepath"       column="filepath"/>
    </resultMap>

    <!-- ==================== 公共查询列 ==================== -->
    <sql id="selectVehicleTemplateVo">
        SELECT template_id,
        wvta_coc_no,
        coc_template_no,
        model_no,
        version,
        vehicle_type,
        status,
        validate_result,
        validate_time,
        validate_msg,
        json,
        remark,
        create_by,
        create_time,
        update_by,
        update_time,
        filepath
        FROM vehicle_template
    </sql>

    <!-- ==================== 查询列表 ==================== -->
    <select id="selectVehicleTemplateList"
            parameterType="com.ruoyi.vehicle.domain.VehicleTemplate"
            resultMap="VehicleTemplateResult">
        <include refid="selectVehicleTemplateVo"/>
        WHERE del_flag = '0'
        <if test="templateIds != null and templateIds.size() > 0">
            AND template_id in
            <foreach item="templateId" collection="templateIds" open="(" separator="," close=")">
                #{templateId}
            </foreach>
        </if>
        <if test="wvtaCocNo != null and wvtaCocNo != ''">
            AND wvta_coc_no LIKE CONCAT('%', #{wvtaCocNo}, '%')
        </if>
        <if test="cocTemplateNo != null and cocTemplateNo != ''">
            AND coc_template_no LIKE CONCAT('%', #{cocTemplateNo}, '%')
        </if>
        <if test="modelNo != null and modelNo != ''">
            AND model_no LIKE CONCAT('%', #{modelNo}, '%')
        </if>
        <if test="vehicleType != null and vehicleType != ''">
            AND vehicle_type = #{vehicleType}
        </if>
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
        <if test="validateResult != null and validateResult != ''">
            AND validate_result = #{validateResult}
        </if>
        ORDER BY create_time DESC
    </select>

    <!-- ==================== 根据ID查询 ==================== -->
    <select id="selectVehicleTemplateById"
            parameterType="java.lang.Long"
            resultMap="VehicleTemplateResult">
        <include refid="selectVehicleTemplateVo"/>
        WHERE del_flag = '0'
            AND template_id = #{templateId}
    </select>

    <!-- ==================== 新增 ==================== -->
    <insert id="insertVehicleTemplate"
            parameterType="com.ruoyi.vehicle.domain.VehicleTemplate"
            useGeneratedKeys="true"
            keyProperty="templateId">
        INSERT INTO vehicle_template (
        wvta_coc_no, coc_template_no,model_no, version, vehicle_type, status, validate_result, json, remark, del_flag, create_by, create_time)
        VALUES (#{wvtaCocNo}, #{cocTemplateNo}, #{modelNo}, #{version}, #{vehicleType}, #{status}, #{validateResult}, #{json}, #{remark}, '0', #{createBy}, #{createTime})
    </insert>

    <!-- ==================== 修改 ==================== -->
    <update id="updateVehicleTemplate"
            parameterType="com.ruoyi.vehicle.domain.VehicleTemplate">
        UPDATE vehicle_template
        <set>
            <if test="wvtaCocNo != null and wvtaCocNo != ''">
                wvta_coc_no = #{wvtaCocNo},
            </if>
            <if test="cocTemplateNo != null and cocTemplateNo != ''">
                coc_template_no = #{cocTemplateNo},
            </if>
            <if test="modelNo != null and modelNo != ''">
                model_no = #{modelNo},
            </if>
            <if test="version != null and version != ''">
                version = #{version},
            </if>
            <if test="vehicleType != null and vehicleType != ''">
                vehicle_type = #{vehicleType},
            </if>
            <if test="json != null">
                json = #{json},
            </if>
            <if test="remark != null">
                remark = #{remark},
            </if>
            <if test="updateBy != null">
                update_by = #{updateBy},
            </if>
            update_time = SYSDATE()
        </set>
        WHERE template_id = #{templateId}
    </update>

    <!-- ==================== 逻辑删除 ==================== -->
    <update id="deleteVehicleTemplateByIds">
        UPDATE vehicle_template
        SET
        del_flag    = '2',
        update_time = SYSDATE()
        WHERE template_id IN
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <!-- ==================== 启用/停用 ==================== -->
    <update id="updateStatus">
        UPDATE vehicle_template
        SET
        status      = #{status},
        update_time = SYSDATE()
        WHERE template_id = #{templateId}
    </update>

    <!-- ==================== 更新单条校验结果 ==================== -->
    <update id="updateValidateResult">
        UPDATE vehicle_template
        SET
        validate_result = #{validateResult},
        validate_msg= #{validateMsg},
        validate_time   = SYSDATE()
        WHERE template_id = #{templateId}
    </update>

    <!-- ==================== 批量更新校验结果（CASE WHEN）==================== -->
    <!--
        生成SQL示例：
        UPDATE vehicle_template
        SET
            validate_result = CASE template_id
                WHEN 1 THEN '1'
                WHEN 2 THEN '2'END,
            validate_msg = CASE template_id
                WHEN 1 THEN'xxx'
                WHEN 2 THEN 'yyy'
            END,
            validate_time = SYSDATE()
        WHERE template_id IN (1, 2)
    -->
    <update id="batchUpdateValidateResult">
        UPDATE vehicle_template
        SET
        validate_result = CASE template_id
        <foreach collection="list" item="item">
            WHEN #{item.templateId} THEN #{item.validateResult}
        </foreach>
        END,
        validate_msg = CASE template_id
        <foreach collection="list" item="item">
            WHEN #{item.templateId} THEN #{item.validateMsg}
        </foreach>
        END,
        validate_time = SYSDATE()
        WHERE template_id IN
        <foreach collection="list" item="item" open="(" separator="," close=")">
            #{item.templateId}
        </foreach>
    </update>

</mapper>