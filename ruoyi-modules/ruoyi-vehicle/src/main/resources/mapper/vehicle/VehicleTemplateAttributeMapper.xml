<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.vehicle.mapper.VehicleTemplateAttributeMapper">

    <resultMap id="VehicleTemplateAttributeResult" type="com.ruoyi.vehicle.domain.VehicleTemplateAttribute">
        <id property="id" column="id"/>
        <result property="templateId" column="template_id"/>
        <result property="attrPath" column="attr_path"/>
        <result property="defaultValue" column="default_value"/>
        <result property="isRequired" column="is_required"/>
        <result property="isEditable" column="is_editable"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <!-- 查询模板下所有属性 -->
    <select id="selectByTemplateId" resultMap="VehicleTemplateAttributeResult">
        SELECT * FROM vehicle_template_attribute
        WHERE template_id = #{templateId}
        ORDER BY sort_order ASC
    </select>

    <!-- 批量查询（用于列表） -->
    <select id="selectByTemplateIds" resultMap="VehicleTemplateAttributeResult">
        SELECT * FROM vehicle_template_attribute
        WHERE template_id IN
        <foreach collection="templateIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY template_id, sort_order ASC
    </select>

    <delete id="deleteByTemplateIds">
        DELETE FROM vehicle_template_attribute
        WHERE template_id IN
        <foreach collection="templateIds" item="templateId" open="(" separator="," close=")">
            #{templateId}
        </foreach>
    </delete>

    <!-- 插入 -->
    <insert id="insert" parameterType="com.ruoyi.vehicle.domain.VehicleTemplateAttribute" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO vehicle_template_attribute (
            template_id, attr_path, default_value, is_required, is_editable, sort_order, create_by, create_time, deleted
        ) VALUES (
                     #{templateId}, #{attrPath}, #{defaultValue}, #{isRequired}, #{isEditable}, #{sortOrder},
                     #{createBy}, #{createTime}, #{deleted}
                 )
    </insert>
</mapper>