<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- SysNoticePostMapper.xml -->
<mapper namespace="com.ruoyi.system.mapper.SysNoticePostMapper">

    <select id="selectPostIdsByNoticeId" resultType="java.lang.Long">
        SELECT post_id
        FROM sys_notice_post
        WHERE notice_id = #{noticeId}
    </select>

    <select id="selectUserIdsByPostIds" resultType="java.lang.Long">
        SELECT DISTINCT user_id
        FROM sys_user_post
        WHERE post_id IN
        <foreach collection="postIds" item="postId" open="(" separator="," close=")">
            #{postId}
        </foreach>
    </select>

</mapper>