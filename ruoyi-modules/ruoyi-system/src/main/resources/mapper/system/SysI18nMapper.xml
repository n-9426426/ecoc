<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysI18nMapper">
    <resultMap type="com.ruoyi.system.domain.SysI18n" id="SysI18nResult">
        <id property="id"          column="id"          />
        <result property="langKey"     column="lang_key"    />
        <result property="langCode"    column="lang_code"   />
        <result property="langValue"   column="lang_value"  />
        <result property="module"      column="module"      />
        <result property="status"      column="status"      />
        <result property="createBy"    column="create_by"   />
        <result property="createTime"  column="create_time" />
        <result property="updateBy"    column="update_by"   />
        <result property="updateTime"  column="update_time" />
        <result property="remark"      column="remark"      />
        <result property="isBackend"   column="is_backend"      />
    </resultMap>

    <!-- 通用查询列-->
    <sql id="selectSysI18nVo">
        select id, lang_key, lang_code, lang_value, module,
            status, create_by, create_time, update_by, update_time, remark, is_backend
        from sys_i18n
    </sql>

    <!-- 条件查询列表 -->
    <select id="selectSysI18nList" parameterType="SysI18n" resultMap="SysI18nResult">
        <include refid="selectSysI18nVo"/>
        <where>
            <if test="langKey != null and langKey != ''">
                and lang_key like concat('%', #{langKey}, '%')
            </if>
            <if test="module != null and module != ''">
                and module = #{module}
            </if>
            <if test="langCode != null and langCode != ''">
                and lang_code = #{langCode}
            </if>
            <if test="langValue != null and langValue != ''">
                and lang_value like concat('%', #{langValue}, '%')
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
            <if test="isBackend != null">
                and is_backend = #{isBackend}
            </if>
        </where>
        order by module asc, lang_key asc
    </select>

    <!-- 根据ID查询 -->
    <select id="selectSysI18nById" parameterType="String" resultMap="SysI18nResult">
        <include refid="selectSysI18nVo"/>
        where id = #{id}
    </select>

    <!-- 校验唯一性 -->
    <select id="checkLangKeyUnique" resultMap="SysI18nResult">
        select id, lang_key, lang_code, is_backend
        from sys_i18n
        where lang_key  = #{langKey} and lang_code = #{langCode} and is_backend = #{isBackend}
            limit 1
    </select>

    <!-- 新增 -->
    <insert id="insertSysI18n" parameterType="SysI18n">
        insert into sys_i18n (
            id,
            lang_key,
            lang_code,
            lang_value,
            module,
            status,
            create_by,
            create_time,
            remark,
            is_backend
        ) values (
                     #{id},
                     #{langKey},
                     #{langCode},
                     #{langValue},
                     #{module},
                     #{status},
                     #{createBy},
                     sysdate(),
                     #{remark},
                     #{isBackend}
                 )
    </insert>

    <!-- 修改 -->
    <update id="updateSysI18n" parameterType="SysI18n">
        update sys_i18n
        <set><if test="langKey != null and langKey != ''">
            lang_key    = #{langKey},
        </if>
            <if test="langCode != null and langCode != ''">
                lang_code   = #{langCode},
            </if>
            <if test="langValue != null and langValue != ''">
                lang_value  = #{langValue},
            </if>
            <if test="module != null">
                module      = #{module},
            </if>
            <if test="status != null">
                status      = #{status},
            </if>
            <if test="updateBy != null and updateBy != ''">
                update_by   = #{updateBy},
            </if>
            <if test="remark != null">
                remark      = #{remark},
            </if>
            <if test="isBackend != null">
                is_backend = #{isBackend},
            </if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <!-- 单条删除 -->
    <delete id="deleteSysI18nById" parameterType="String">
        delete from sys_i18n where id = #{id}
    </delete>

    <!-- 批量删除 -->
    <delete id="deleteSysI18nByIds" parameterType="String">
        delete from sys_i18n where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 根据语言代码查询所有有效翻译（用于缓存） -->
    <select id="selectByLangCode" parameterType="String" resultMap="SysI18nResult">
        select lang_key, lang_value
        from sys_i18n
        where lang_code = #{langCode} and is_backend = 1
          and status    = 0
    </select>

    <!-- 根据翻译键+语言代码查询单条翻译值 -->
    <select id="selectValueByKeyAndLang" resultType="String">
        select lang_value
        from sys_i18n
        where lang_key  = #{langKey}
          and lang_code = #{langCode}
          and status    = 0
            limit 1
    </select>

    <!-- 批量查询翻译 -->
    <select id="selectByKeysAndLang" resultMap="SysI18nResult">
        select lang_key, lang_value
        from sys_i18n
        where lang_code = #{langCode}
        and status    = 0
        and lang_key in
        <foreach collection="langKeys" item="key" open="(" separator="," close=")">
            #{key}
        </foreach>
    </select>

</mapper>